# ================================================================
# VERCEL ENVIRONMENT VARIABLES — Frontend
# ================================================================
# Set in: Vercel Dashboard → Your Project → Settings → Environment Variables
# ================================================================

# ─── Backend API URL (required for production) ────────────
# Your deployed BACKEND Vercel URL — no trailing slash, no /api suffix
# e.g. https://ai-buisness-assistant-backend.vercel.app
#
# Leave EMPTY in development — Vite proxy handles /api → localhost:3000
VITE_API_URL=https://your-backend.vercel.app
