# ─── Frontend Environment Variables ──────────────────────
#
# Copy this file to .env.local for local development
# For Vercel: set these in Project Settings → Environment Variables
#
# ─── Development (optional) ───────────────────────────────
# Leave empty in development — Vite proxy handles /api → localhost:3000
# VITE_API_URL=

# ─── Production (required on Vercel) ─────────────────────
# Your deployed backend URL — no trailing slash, no /api suffix
# Example: https://ai-business-assistant.onrender.com
VITE_API_URL=https://your-backend-url.onrender.com
