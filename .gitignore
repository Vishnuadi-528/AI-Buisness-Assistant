# Root-level gitignore — covers both backend and frontend

# Dependencies
node_modules/
**/node_modules/

# Environment files — NEVER commit secrets
.env
.env.local
.env.production
.env.*.local
**/.env
**/.env.local
**/.env.production

# Keep example files
!.env.example
!**/.env.example

# Build output
dist/
**/dist/
coverage/
**/coverage/

# Logs
*.log
npm-debug.log*
**/npm-debug.log*

# OS
.DS_Store
Thumbs.db
**/Thumbs.db

# Editor
.vscode/
.idea/

# Vite
*.local
