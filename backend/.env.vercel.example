# ================================================================
# VERCEL ENVIRONMENT VARIABLES — Backend
# ================================================================
# Set ALL of these in:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
#
# Select Environments: Production + Preview + Development
# ================================================================

# ─── MongoDB Atlas (required) ─────────────────────────────
# Get from: https://cloud.mongodb.com
# Create free M0 cluster → Connect → Drivers → copy string
# Replace <username>, <password>, <cluster> with your values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai_business_assistant?retryWrites=true&w=majority

# ─── JWT Secrets (required) ───────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=generate_a_long_random_string_here
JWT_REFRESH_SECRET=generate_a_different_long_random_string_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Groq API (required) ──────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
AI_MAX_TOKENS=8000

# ─── CORS (required) ──────────────────────────────────────
# Your Vercel frontend URL — no trailing slash
# e.g. https://ai-buisness-assistant.vercel.app
# Multiple URLs: comma-separated
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ─── Rate Limiting (optional) ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_RATE_LIMIT_MAX=10

# ─── App Config (required) ────────────────────────────────
NODE_ENV=production
BCRYPT_SALT_ROUNDS=12
LOG_LEVEL=info
