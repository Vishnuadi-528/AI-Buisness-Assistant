# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ──────────────────────────────────────────────
# Local:   mongodb://localhost:27017/ai_business_assistant
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/ai_business_assistant
MONGODB_URI=mongodb://localhost:27017/ai_business_assistant

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=5rVWlhY2WdC2g0eV/StQIXjXqfvOhlTT44siaWJ5+nE=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google Gemini API ────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your-real-gemini-key-here
GEMINI_MODEL=gemini-1.5-flash
AI_MAX_TOKENS=8000

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_RATE_LIMIT_MAX=10

# ─── Bcrypt ───────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
